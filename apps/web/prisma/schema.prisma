generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (better-auth) ─────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  phone         String?
  image         String?
  role          Role      @default(CONSUMER)
  points        Int       @default(0)
  vipLevel      Int       @default(0)
  vipExpiresAt  DateTime?
  inviteCode    String?   @unique
  invitedById   String?
  invitedBy     User?     @relation("Referral", fields: [invitedById], references: [id])
  referrals     User[]    @relation("Referral")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions           Session[]
  accounts           Account[]
  orders             Order[]
  coupons            Coupon[]
  checkins           Checkin[]
  taskCompletions    TaskCompletion[]
  verifications      VerificationRecord[] @relation("VerifiedBy")
  posts              Post[]
  comments           Comment[]
  favorites          Favorite[]
  footprints         Footprint[]
  agentApplication   AgentApplication?

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

enum Role {
  CONSUMER
  MERCHANT
  AGENT
  ADMIN
}

// ─── Products / Scrolls ─────────────────────────────

model Product {
  id                String   @id @default(cuid())
  app               String
  title             String
  subtitle          String   @default("")
  description       String   @default("")
  category          String   @default("today")
  imageUrl          String?
  coverImage        String?
  pointsPrice       Int      @default(0)
  cashPrice         Decimal  @default(0) @db.Decimal(10, 2)
  originalCashPrice Decimal? @db.Decimal(10, 2)
  stock             Int      @default(0)
  minAmount         Decimal? @db.Decimal(10, 2)
  minQuantity       Int?
  purchaseNotes     String[] @default([])
  usageNotes        String?
  agentPrice        Decimal? @db.Decimal(10, 2)
  agentMinQty       Int?
  expiresAt         DateTime
  tags              String[] @default([])
  status            ProductStatus @default(ACTIVE)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orders     Order[]
  coupons    Coupon[]
  favorites  Favorite[]
  footprints Footprint[]

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  SOLD_OUT
  EXPIRED
  DRAFT
}

// ─── Orders ─────────────────────────────────────────

model Order {
  id             String      @id @default(cuid())
  userId         String
  productId      String
  qty            Int         @default(1)
  cashPaid       Decimal     @db.Decimal(10, 2)
  pointsPaid     Int         @default(0)
  payMethod      String
  serialNo       String?     @unique
  status         OrderStatus @default(PENDING)
  paidAt         DateTime?
  expiresAt      DateTime?
  deliveryStatus String?
  deliveryCount  Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  product Product  @relation(fields: [productId], references: [id])
  coupon  Coupon?
  coupons Coupon[] @relation("BulkCoupons")

  @@index([userId, status])
  @@index([productId])
  @@index([createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

// ─── Coupons ────────────────────────────────────────

model Coupon {
  id           String       @id @default(cuid())
  code         String       @unique
  userId       String
  productId    String
  orderId      String       @unique
  bulkOrderId  String?
  status       CouponStatus @default(ACTIVE)
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime     @default(now())

  user      User    @relation(fields: [userId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id])
  bulkOrder Order?  @relation("BulkCoupons", fields: [bulkOrderId], references: [id])
  verificationRecords VerificationRecord[]

  @@index([userId, status])
  @@index([productId])
  @@index([bulkOrderId])
  @@map("coupons")
}

enum CouponStatus {
  ACTIVE
  USED
  EXPIRED
}

// ─── Verification / 核销 ────────────────────────────

model VerificationRecord {
  id         String   @id @default(cuid())
  couponId   String
  verifiedBy String
  notes      String   @default("")
  verifiedAt DateTime @default(now())

  coupon   Coupon @relation(fields: [couponId], references: [id])
  verifier User   @relation("VerifiedBy", fields: [verifiedBy], references: [id])

  @@index([couponId])
  @@index([verifiedBy])
  @@index([verifiedAt])
  @@map("verification_records")
}

// ─── Checkin / 签到 ─────────────────────────────────

model Checkin {
  id        String   @id @default(cuid())
  userId    String
  dayIndex  Int
  reward    Int
  checkedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, checkedAt])
  @@index([userId, checkedAt])
  @@map("checkins")
}

// ─── Task Completion / 任务 ─────────────────────────

model TaskCompletion {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  reward    Int      @default(0)
  doneAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, taskId, doneAt])
  @@index([userId, doneAt])
  @@map("task_completions")
}

// ─── Posts / 帖子 ──────────────────────────────────

model Post {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  images    String[]
  likeCount Int      @default(0)
  app       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  comments Comment[]

  @@index([userId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.VarChar(500)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
  @@map("comments")
}

// ─── Favorites / 收藏 ─────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("favorites")
}

// ─── Footprints / 足迹 ────────────────────────────

model Footprint {
  id        String   @id @default(cuid())
  userId    String
  productId String
  viewedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([userId, viewedAt])
  @@map("footprints")
}

// ─── Agent Application / 代理申请 ─────────────────

enum AgentStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  DEPLOYED
}

model AgentApplication {
  id               String      @id @default(cuid())
  userId           String      @unique
  realName         String
  region           String
  platforms        String[]
  qualificationUrl String?
  status           AgentStatus @default(PENDING)
  reviewNote       String?
  reviewedAt       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("agent_applications")
}
