{
  "name": "discount-hub",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "mobile:tauri": "pnpm --filter mobile tauri",
    "mobile:desktop:dev": "pnpm --filter mobile desktop:dev",
    "mobile:desktop:build": "pnpm --filter mobile desktop:build",
    "mobile:ios:dev": "pnpm --filter mobile ios:dev",
    "mobile:ios:build": "pnpm --filter mobile ios:build",
    "mobile:android:dev": "pnpm --filter mobile android:dev",
    "mobile:android:build": "pnpm --filter mobile android:build"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=18.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "better-sqlite3",
      "sharp",
      "unrs-resolver",
      "esbuild"
    ]
  }
}
